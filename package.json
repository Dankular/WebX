{
  "name": "webx",
  "version": "0.1.0",
  "description": "Web-based DirectX/Steam game rendering via Canary (x86-64 WASM) + Proton + WebGPU",
  "type": "module",
  "scripts": {
    "dev": "node harness/server.mjs",
    "extract:image": "python steam/extract-image.py",
    "extract:rootfs": "bash steam/extract-rootfs.sh steam/steamdeck-repair.img steam/",
    "build:icd": "cmake -B build/guest-icd guest-icd/ -DCMAKE_TOOLCHAIN_FILE=cmake/x86_64-linux-gnu.cmake -DCMAKE_BUILD_TYPE=Release && cmake --build build/guest-icd",
    "build:icd:docker": "docker run --rm -v .:/work ubuntu:24.04 bash -c 'apt-get install -yq cmake gcc-x86-64-linux-gnu libvulkan-dev libxcb1-dev && cd /work && npm run build:icd'",
    "build:canary": "cd ../Canary && npm run build:wasm",
    "build:vkwebgpu:linux": "bash steam/build-vkwebgpu.sh",
    "update:icd": "bash steam/update-icd.sh steam/steamos-webx.ext2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
